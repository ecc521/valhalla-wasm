{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "web",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "verbatimModuleSyntax": true
  },
  "include": ["web/index.ts", "web/types.ts", "web/tileSource.ts", "web/routingCore.ts"]
}
